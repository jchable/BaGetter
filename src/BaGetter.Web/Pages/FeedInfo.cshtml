        </div>
    </div>
</div>

<h2>Symbol server (debugging)</h2>

<div class="card mb-4">
    <div class="card-body">
        <p>To load symbols when debugging, add this URL as a symbol server in Visual Studio:</p>
        <p><strong>Debug &gt; Options &gt; Debugging &gt; Symbols &gt; New location</strong></p>
        <div class="d-flex align-items-center gap-2">
            <code class="user-select-all flex-grow-1">@symbolServerUrl</code>
            <button class="btn btn-sm btn-warning" type="button"
                    data-bs-toggle="popover" data-bs-placement="bottom" data-bs-content="Copied"
                    onclick="window.baget.copyTextToClipboard('@symbolServerUrl', this)">
                <i class="ms-Icon ms-Icon--Copy"></i>
            </button>
        </div>
    </div>
</div>

<script type="text/javascript">
    let addSourceTabs = [
        {
            name: ".NET CLI",
            content: ["dotnet nuget add source @serviceIndexUrl --name BaGetter"],
        },
        {
            name: "NuGet CLI",
            content: ["nuget sources add -Name BaGetter -Source @serviceIndexUrl"],
        },
        {
            name: "Visual Studio",
            content: [
                "1. Go to Tools > NuGet Package Manager > Package Manager Settings",
                "2. Select Package Sources",
                "3. Click the + button to add a new source",
                "4. Set Name to \"BaGetter\" and Source to:",
                "   @serviceIndexUrl",
                "5. Click Update, then OK"
            ],
        },
        {
            name: "nuget.config",
            content: [
                "<configuration>",
                "  <packageSources>",
                "    <add key=\"BaGetter\" value=\"@serviceIndexUrl\" />",
                "  </packageSources>",
                "</configuration>"
            ],
        },
    ];

    let pushTabs = [
        {
            name: ".NET CLI",
            content: ["dotnet nuget push -s @serviceIndexUrl -k YOUR_API_KEY package.nupkg"],
        },
        {
            name: "NuGet CLI",
            content: ["nuget push -Source @serviceIndexUrl -ApiKey YOUR_API_KEY package.nupkg"],
        },
        {
            name: "Paket",
            content: ["paket push --url @baseUrl --api-key YOUR_API_KEY package.nupkg"],
        },
    ];

    let symbolTabs = [
        {
            name: ".NET CLI",
            content: ["dotnet nuget push -s @serviceIndexUrl -k YOUR_API_KEY package.snupkg"],
        },
        {
            name: "NuGet CLI",
            content: ["nuget push -Source @serviceIndexUrl -ApiKey YOUR_API_KEY package.snupkg"],
        },
    ];
</script>
