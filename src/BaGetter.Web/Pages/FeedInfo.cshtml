@page "/feed-info"
@inject IUrlGenerator _url

@{
    ViewData["Title"] = "Feed Info";

    var serviceIndexUrl = _url.GetServiceIndexUrl();
    var publishUrl = _url.GetPackagePublishResourceUrl();
    var symbolPublishUrl = _url.GetSymbolPublishResourceUrl();
    var baseUrl = Url.PageLink("/Index")?.TrimEnd('/');
    var symbolServerUrl = baseUrl + "/api/download/symbols";
}

<h1>Feed Info</h1>
<hr />

<p>Use the URLs below to connect your NuGet clients to this feed.</p>

<div class="card mb-4">
    <div class="card-header"><strong>Feed URLs</strong></div>
    <div class="card-body p-0">
        <table class="table table-borderless mb-0">
            <tbody>
                <tr>
                    <td class="text-nowrap pe-3"><strong>NuGet V3 Feed URL</strong></td>
                    <td class="w-100">
                        <div class="d-flex align-items-center gap-2">
                            <code class="user-select-all flex-grow-1">@serviceIndexUrl</code>
                            <button class="btn btn-sm btn-warning" type="button"
                                    data-bs-toggle="popover" data-bs-placement="bottom" data-bs-content="Copied"
                                    onclick="window.baget.copyTextToClipboard('@serviceIndexUrl', this)">
                                <i class="ms-Icon ms-Icon--Copy"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td class="text-nowrap pe-3"><strong>Package Push URL</strong></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <code class="user-select-all flex-grow-1">@publishUrl</code>
                            <button class="btn btn-sm btn-warning" type="button"
                                    data-bs-toggle="popover" data-bs-placement="bottom" data-bs-content="Copied"
                                    onclick="window.baget.copyTextToClipboard('@publishUrl', this)">
                                <i class="ms-Icon ms-Icon--Copy"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td class="text-nowrap pe-3"><strong>Symbol Push URL</strong></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <code class="user-select-all flex-grow-1">@symbolPublishUrl</code>
                            <button class="btn btn-sm btn-warning" type="button"
                                    data-bs-toggle="popover" data-bs-placement="bottom" data-bs-content="Copied"
                                    onclick="window.baget.copyTextToClipboard('@symbolPublishUrl', this)">
                                <i class="ms-Icon ms-Icon--Copy"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td class="text-nowrap pe-3"><strong>Symbol Server URL</strong></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <code class="user-select-all flex-grow-1">@symbolServerUrl</code>
                            <button class="btn btn-sm btn-warning" type="button"
                                    data-bs-toggle="popover" data-bs-placement="bottom" data-bs-content="Copied"
                                    onclick="window.baget.copyTextToClipboard('@symbolServerUrl', this)">
                                <i class="ms-Icon ms-Icon--Copy"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<h2>Add as package source</h2>

<div class="tabbed-info" x-data="{ tabs: addSourceTabs, active: addSourceTabs[0] }">
    <ul class="nav tab-nav">
        <template x-for="tab in tabs" :key="tab.name">
            <li x-bind:class="{ 'active': active.name === tab.name }">
                <a href="#" x-text="tab.name" @@click.prevent="active = tab"></a>
            </li>
        </template>
    </ul>

    <div class="tab-content-box">
        <div class="tab-script">
            <template x-for="line in active.content">
                <div class="tab-script-line" x-text="line"></div>
            </template>
        </div>

        <div class="tab-copy">
            <button class="btn btn-warning"
                    type="button"
                    data-bs-toggle="popover"
                    data-bs-placement="bottom"
                    data-bs-content="Copied"
                    @@click="window.baget.copyTextToClipboard(active.content.join('\n'), $el)">
                <i class="ms-Icon ms-Icon--Copy"></i>
            </button>
        </div>
    </div>
</div>

<h2>Push packages</h2>

<div class="tabbed-info" x-data="{ tabs: pushTabs, active: pushTabs[0] }">
    <ul class="nav tab-nav">
        <template x-for="tab in tabs" :key="tab.name">
            <li x-bind:class="{ 'active': active.name === tab.name }">
                <a href="#" x-text="tab.name" @@click.prevent="active = tab"></a>
            </li>
        </template>
    </ul>

    <div class="tab-content-box">
        <div class="tab-script">
            <template x-for="line in active.content">
                <div class="tab-script-line" x-text="line"></div>
            </template>
        </div>

        <div class="tab-copy">
            <button class="btn btn-warning"
                    type="button"
                    data-bs-toggle="popover"
                    data-bs-placement="bottom"
                    data-bs-content="Copied"
                    @@click="window.baget.copyTextToClipboard(active.content.join('\n'), $el)">
