@page "/admin/audit-log"
@model AuditLogModel
@using BaGetter.Core

@{
    ViewData["Title"] = "Audit Log";
}

<div class="container mt-4">
    <h1>Audit Log</h1>

    <form method="get" class="row g-3 align-items-end mb-4">
        <div class="col-md-3">
            <label for="action" class="form-label">Action</label>
            <select name="action" id="action" class="form-select">
                <option value="">All</option>
                @foreach (var a in new[] {
                    AuditAction.PackagePushed, AuditAction.PackageDeleted,
                    AuditAction.PackageUnlisted, AuditAction.PackageRelisted,
                    AuditAction.LoginSuccess, AuditAction.LoginFailure,
                    AuditAction.RoleChanged, AuditAction.UserDeleted,
                    AuditAction.InvitationCreated, AuditAction.InvitationRevoked,
                    AuditAction.ApiKeyCreated, AuditAction.ApiKeyRevoked })
                {
                    <option value="@a" selected="@(Model.ActionFilter == a)">@a</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label for="userId" class="form-label">User ID</label>
            <input type="text" name="userId" id="userId" class="form-control"
                   value="@Model.UserFilter" placeholder="Filter by user ID" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped table-sm">
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Resource</th>
                    <th>Details</th>
                    <th>IP</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs)
                {
                    <tr>
                        <td class="text-nowrap">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@(log.UserName ?? log.UserId ?? "—")</td>
                        <td><span class="badge bg-secondary">@log.Action</span></td>
                        <td>
                            @if (log.ResourceType != null)
                            {
                                <span>@log.ResourceType</span>
                                @if (log.ResourceId != null)
                                {
                                    <span class="text-muted"> / @log.ResourceId</span>
                                }
                            }
                        </td>
                        <td class="text-truncate" style="max-width: 200px;" title="@log.Details">
                            @(log.Details?.Length > 60 ? log.Details[..60] + "…" : log.Details)
                        </td>
                        <td>@log.IpAddress</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Audit log pagination">
            <ul class="pagination justify-content-center">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="?page=@(Model.CurrentPage - 1)&action=@Model.ActionFilter&userId=@Model.UserFilter">Previous</a>
                    </li>
                }
                <li class="page-item disabled">
                    <span class="page-link">Page @Model.CurrentPage / @Model.TotalPages</span>
                </li>
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="?page=@(Model.CurrentPage + 1)&action=@Model.ActionFilter&userId=@Model.UserFilter">Next</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
