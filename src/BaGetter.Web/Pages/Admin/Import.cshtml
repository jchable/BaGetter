@page "/admin/import"
@model ImportModel

@{
    ViewData["Title"] = "Import Feed";
}

<div class="container mt-4">
    <h1>Import Feed</h1>
    <p class="text-muted">Import all packages from a remote NuGet feed. The operation is idempotent: existing packages are skipped.</p>

    <!-- Form (hidden when import is running) -->
    <div id="import-form" class="card mb-4" @(Model.IsRunning ? "style=display:none" : "")>
        <div class="card-header">Remote feed configuration</div>
        <div class="card-body">
            <div class="mb-3">
                <label for="feedUrl" class="form-label">Feed URL</label>
                <input type="url" class="form-control" id="feedUrl" placeholder="https://www.myget.org/F/my-feed/api/v2" required />
                <div class="form-text">NuGet v3 service index URL or v2 feed URL.</div>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="legacy">
                <label class="form-check-label" for="legacy">Legacy feed (NuGet v2 / OData)</label>
            </div>

            <div class="mb-3">
                <label for="authType" class="form-label">Authentication</label>
                <select class="form-select" id="authType">
                    <option value="0">None</option>
                    <option value="apikey">API Key</option>
                    <option value="1">Basic (username / password)</option>
                </select>
            </div>

            <div id="auth-apikey" class="mb-3" style="display:none">
                <label for="apiKey" class="form-label">API Key</label>
                <input type="password" class="form-control" id="apiKey" />
            </div>

            <div id="auth-basic" style="display:none">
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="username" />
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password" />
                </div>
            </div>

            <button type="button" id="btn-start" class="btn btn-primary" onclick="startImport()">Start Import</button>
        </div>
    </div>

    <!-- Progress (hidden by default) -->
    <div id="import-progress" class="card mb-4" style="display:none">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Import Progress</span>
            <button type="button" id="btn-cancel" class="btn btn-sm btn-outline-danger" onclick="cancelImport()">Cancel</button>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <div class="progress" style="height: 24px;">
                    <div id="progress-bar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%">0%</div>
                </div>
            </div>

            <div class="row text-center mb-3">
                <div class="col">
                    <span class="text-muted">Total</span>
                    <div id="stat-total" class="fs-4">-</div>
                </div>
                <div class="col">
                    <span class="text-success">Imported</span>
                    <div id="stat-imported" class="fs-4 text-success">0</div>
                </div>
                <div class="col">
                    <span class="text-secondary">Skipped</span>
                    <div id="stat-skipped" class="fs-4 text-secondary">0</div>
                </div>
                <div class="col">
                    <span class="text-danger">Failed</span>
                    <div id="stat-failed" class="fs-4 text-danger">0</div>
                </div>
            </div>

            <div id="current-package" class="text-muted mb-3"></div>
        </div>
    </div>

    <!-- Result (hidden by default) -->
    <div id="import-result" class="card mb-4" style="display:none">
        <div class="card-header">Import Complete</div>
        <div class="card-body">
            <div id="result-summary" class="mb-3"></div>
            <div id="result-errors" style="display:none">
                <h6 class="text-danger">Errors:</h6>
                <pre id="error-list" class="bg-light p-3 rounded" style="max-height: 300px; overflow-y: auto;"></pre>
            </div>
            <button type="button" class="btn btn-primary mt-2" onclick="resetForm()">New Import</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const authSelect = document.getElementById('authType');
    authSelect.addEventListener('change', function () {
        document.getElementById('auth-apikey').style.display = this.value === 'apikey' ? '' : 'none';
        document.getElementById('auth-basic').style.display = this.value === '1' ? '' : 'none';
    });

    function startImport() {
        const feedUrl = document.getElementById('feedUrl').value.trim();
        if (!feedUrl) { alert('Feed URL is required.'); return; }

        const legacy = document.getElementById('legacy').checked;
        const authTypeVal = authSelect.value;

        const body = { feedUrl, legacy };

        if (authTypeVal === 'apikey') {
            body.authType = 0; // None — API key sent separately
            body.apiKey = document.getElementById('apiKey').value;
        } else if (authTypeVal === '1') {
            body.authType = 1; // Basic
            body.username = document.getElementById('username').value;
            body.password = document.getElementById('password').value;
        } else {
            body.authType = 0;
        }

        document.getElementById('btn-start').disabled = true;

        fetch('/admin/api/import/start', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        })
        .then(r => {
            if (!r.ok) return r.json().then(d => { throw new Error(d.error || 'Failed to start import'); });
            document.getElementById('import-form').style.display = 'none';
            document.getElementById('import-progress').style.display = '';
            document.getElementById('import-result').style.display = 'none';
            listenProgress();
        })
        .catch(err => {
            alert(err.message);
            document.getElementById('btn-start').disabled = false;
        });
    }

    function cancelImport() {
        if (!confirm('Cancel the current import?')) return;
        fetch('/admin/api/import/cancel', { method: 'POST' });
    }

    function listenProgress() {
        const es = new EventSource('/admin/api/import/progress');
        es.onmessage = function (e) {
            const p = JSON.parse(e.data);
            updateProgress(p);
            if (p.isComplete) {
                es.close();
                showResult(p);
            }
        };
        es.onerror = function () {
            // Reconnect is automatic with EventSource, but if the stream ends we show what we have
            setTimeout(() => {
                fetch('/admin/api/import/status')
                    .then(r => r.json())
                    .then(d => {
                        if (d.progress) {
                            updateProgress(d.progress);
                            if (d.progress.isComplete) showResult(d.progress);
                        }
                    });
            }, 1000);
        };
    }

    function updateProgress(p) {
        const processed = p.imported + p.skipped + p.failed;
        const total = p.totalVersions || 0;
        const pct = total > 0 ? Math.round((processed / total) * 100) : 0;

        const bar = document.getElementById('progress-bar');
        bar.style.width = pct + '%';
        bar.textContent = pct + '%';

        document.getElementById('stat-total').textContent = total || '-';
        document.getElementById('stat-imported').textContent = p.imported;
        document.getElementById('stat-skipped').textContent = p.skipped;
        document.getElementById('stat-failed').textContent = p.failed;
        document.getElementById('current-package').textContent = p.currentPackage || '';
    }

    function showResult(p) {
        document.getElementById('btn-cancel').style.display = 'none';
        const bar = document.getElementById('progress-bar');
        bar.classList.remove('progress-bar-animated');

        if (p.failed === 0) {
            bar.classList.remove('bg-danger');
            bar.classList.add('bg-success');
        } else {
            bar.classList.add('bg-warning');
        }

        const summary = document.getElementById('result-summary');
        summary.innerHTML = `<strong>${p.imported}</strong> package(s) imported, <strong>${p.skipped}</strong> skipped (already exist), <strong>${p.failed}</strong> failed.`;

        if (p.errors && p.errors.length > 0) {
            document.getElementById('result-errors').style.display = '';
            document.getElementById('error-list').textContent = p.errors.join('\n');
        }

        document.getElementById('import-result').style.display = '';
    }

    function resetForm() {
        document.getElementById('import-form').style.display = '';
        document.getElementById('import-progress').style.display = 'none';
        document.getElementById('import-result').style.display = 'none';
        document.getElementById('result-errors').style.display = 'none';
        document.getElementById('btn-start').disabled = false;
        document.getElementById('btn-cancel').style.display = '';

        const bar = document.getElementById('progress-bar');
        bar.style.width = '0%';
        bar.textContent = '0%';
        bar.classList.add('progress-bar-animated');
        bar.classList.remove('bg-success', 'bg-warning', 'bg-danger');
    }

    // If import is already running on page load, show progress
    @if (Model.IsRunning)
    {
        @:document.getElementById('import-form').style.display = 'none';
        @:document.getElementById('import-progress').style.display = '';
        @:listenProgress();
    }
</script>
}
