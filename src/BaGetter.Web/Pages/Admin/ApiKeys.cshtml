@page "/admin/api-keys"
@model ApiKeysModel
@using BaGetter.Core

@{
    ViewData["Title"] = "API Keys";
}

<div class="container mt-4">
    <h1>API Keys</h1>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.NewlyCreatedKey))
    {
        <div class="alert alert-warning" role="alert">
            <strong>Your new API key (copy it now — it won't be shown again):</strong>
            <code class="user-select-all d-block mt-2 fs-5">@Model.NewlyCreatedKey</code>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header">Create new API key</div>
        <div class="card-body">
            <form method="post" asp-page-handler="Create" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label asp-for="Input.Name" class="form-label">Name</label>
                    <input asp-for="Input.Name" class="form-control" placeholder="e.g. CI Pipeline" />
                    <span asp-validation-for="Input.Name" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Input.Role" class="form-label">Role</label>
                    <select asp-for="Input.Role" class="form-select">
                        <option value="@Roles.Publisher">Publisher</option>
                        <option value="@Roles.Reader">Reader</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="Input.ExpiresAt" class="form-label">Expires (optional)</label>
                    <input asp-for="Input.ExpiresAt" type="date" class="form-control" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Create</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Prefix</th>
                    <th>Owner</th>
                    <th>Role</th>
                    <th>Created</th>
                    <th>Expires</th>
                    <th>Last used</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var key in Model.KeyList)
                {
                    var isExpired = key.ExpiresAt.HasValue && key.ExpiresAt < DateTimeOffset.UtcNow;
                    <tr class="@(key.IsRevoked || isExpired ? "text-muted" : "")">
                        <td>@key.Name</td>
                        <td><code>@key.KeyPrefix…</code></td>
                        <td>@(key.User?.Email ?? key.UserId)</td>
                        <td><span class="badge bg-secondary">@key.Role</span></td>
                        <td>@key.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>@(key.ExpiresAt?.ToString("yyyy-MM-dd") ?? "Never")</td>
                        <td>@(key.LastUsedAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                        <td>
                            @if (key.IsRevoked)
                            {
                                <span class="badge bg-danger">Revoked</span>
                            }
                            else if (isExpired)
                            {
                                <span class="badge bg-warning text-dark">Expired</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </td>
                        <td>
                            @if (!key.IsRevoked)
                            {
                                <form method="post" asp-page-handler="Revoke" class="d-inline">
                                    <input type="hidden" name="keyId" value="@key.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Revoke this API key?')">Revoke</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
