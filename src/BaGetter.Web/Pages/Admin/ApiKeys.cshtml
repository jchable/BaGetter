@page "/admin/api-keys"
@model ApiKeysModel

@{
    ViewData["Title"] = "API Keys";
}

<div class="container mt-4">
    <h1>API Keys</h1>

    <div class="card mb-4">
        <div class="card-header">Configuration status</div>
        <div class="card-body">
            <table class="table mb-0">
                <tbody>
                    <tr>
                        <td>Global API key (<code>ApiKey</code>)</td>
                        <td>
                            @if (Model.HasGlobalKey)
                            {
                                <span class="badge bg-success">Configured</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Not set</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td>Additional keys (<code>Authentication:ApiKeys</code>)</td>
                        <td>
                            @if (Model.ConfiguredKeyCount > 0)
                            {
                                <span class="badge bg-success">@Model.ConfiguredKeyCount key(s)</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">None</span>
                            }
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header">How to configure</div>
        <div class="card-body">
            <p>API keys are configured in <code>appsettings.json</code> or via environment variables:</p>
            <pre class="bg-dark text-light p-3 rounded"><code>{
  "ApiKey": "your-global-api-key",
  "Authentication": {
    "ApiKeys": [
      { "Key": "ci-pipeline-key-1" },
      { "Key": "ci-pipeline-key-2" }
    ]
  }
}</code></pre>
            <p class="text-muted mb-0">
                NuGet clients use the key via: <code>dotnet nuget push -k &lt;api-key&gt; -s &lt;feed-url&gt;</code>
            </p>
        </div>
    </div>
</div>
