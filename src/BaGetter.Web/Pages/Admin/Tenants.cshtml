@page "/admin/tenants"
@model TenantsModel

@{
    ViewData["Title"] = "Tenants";
}

<div class="container mt-4">
    <h1>Tenants</h1>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
    }

    <div class="card mb-4">
        <div class="card-header">Create new tenant</div>
        <div class="card-body">
            <form method="post" asp-page-handler="Create" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label asp-for="Input.Name" class="form-label">Name</label>
                    <input asp-for="Input.Name" class="form-control" placeholder="e.g. Acme Corp" />
                    <span asp-validation-for="Input.Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.Slug" class="form-label">Slug</label>
                    <input asp-for="Input.Slug" class="form-control" placeholder="e.g. acme-corp" />
                    <span asp-validation-for="Input.Slug" class="text-danger small"></span>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Create</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Slug</th>
                    <th>Users</th>
                    <th>Packages</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var info in Model.TenantList)
                {
                    <tr>
                        <td>@info.Tenant.Name</td>
                        <td><code>@info.Tenant.Slug</code></td>
                        <td>@info.UserCount</td>
                        <td>@info.PackageCount</td>
                        <td>@info.Tenant.CreatedAt.ToString("yyyy-MM-dd")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
