@page "/account/external-login"
@model ExternalLoginModel

@{
    ViewData["Title"] = "Sign in";
    Layout = "_AuthLayout";
}

<div class="auth-card">
    <div class="auth-logo">
        <span class="auth-brand">BaGetter</span>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        <a asp-page="/Account/Login" class="btn btn-outline-secondary w-100">Back to sign in</a>
    }
    else if (Model.ShowConfirmForm)
    {
        <h1 class="auth-title">Confirm your email</h1>
        <p class="auth-subtitle text-muted">We received your @Model.ProviderDisplayName account. Please confirm your email to continue.</p>

        <form method="post" asp-page-handler="Confirm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="email" autofocus />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <input type="hidden" asp-for="ReturnUrl" />
            <button type="submit" class="btn btn-primary w-100">Continue</button>
        </form>
    }
    else
    {
        <p class="text-center text-muted">Signing you in…</p>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
