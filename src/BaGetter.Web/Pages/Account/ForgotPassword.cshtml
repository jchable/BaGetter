@page "/account/forgot-password"
@model ForgotPasswordModel

@{
    ViewData["Title"] = "Reset password";
    Layout = "_AuthLayout";
}

<div class="auth-card">
    <div class="auth-logo">
        <span class="auth-brand">BaGetter</span>
    </div>

    <h1 class="auth-title">Reset your password</h1>

    @if (Model.EmailSent)
    {
        <div class="alert alert-success" role="alert">
            If that email is registered, you'll receive a reset link shortly.
        </div>
        <a asp-page="/Account/Login" class="btn btn-outline-secondary w-100">Back to sign in</a>
    }
    else
    {
        <p class="auth-subtitle text-muted">Enter your email and we'll send you a reset link.</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="email" autofocus />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Send reset link</button>
        </form>

        <div class="mt-3 text-center">
            <a asp-page="/Account/Login" class="small">Back to sign in</a>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
