@page "/account/access-denied"
@model AccessDeniedModel

@{
    ViewData["Title"] = "Access denied";
    Layout = "_AuthLayout";
}

<div class="auth-card">
    <div class="auth-logo">
        <span class="auth-brand">BaGetter</span>
    </div>

    <h1 class="auth-title">Access denied</h1>
    <p class="auth-subtitle text-muted">You don't have permission to access this page.</p>

    <a asp-page="/Account/Login" class="btn btn-primary w-100">Back to sign in</a>
</div>
