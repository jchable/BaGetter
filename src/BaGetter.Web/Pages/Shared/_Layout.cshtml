@using BaGetter.Web.Extensions
@using BaGetter.Web.Helper
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Microsoft.Extensions.Options
@using Microsoft.AspNetCore.Identity

@inject IOptions<StatisticsOptions> StatisticsOptions
@inject ApplicationVersion Version

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="BaGetter">
    <meta name="author" content="@Version.Authors">
    @Html.AddReleaseMetaTags()

    <link rel="shortcut icon" href="~/_content/BaGetter.Web/favicon.ico">

    <link rel="stylesheet" href="~/_content/BaGetter.Web/lib/bootstrap/dist/css/bootstrap.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/_content/BaGetter.Web/lib/office-ui-fabric-core/dist/css/fabric.min.css" />
    <link rel="stylesheet" href="~/_content/BaGetter.Web/css/site.css" />

    <title>@ViewData["Title"] - BaGetter</title>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-dark">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">BaGetter</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a asp-area="" asp-page="/Index" class="nav-link">Packages</a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="" asp-page="/Upload" class="nav-link">Upload</a>
                        </li>
                        @if (StatisticsOptions.Value.EnableStatisticsPage)
                        {
                            <li class="nav-item">
                                <a asp-area="" asp-page="/Statistics" class="nav-link">Statistics</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" href="https://www.bagetter.com/docs" target="_blank" rel="noopener noreferrer">
                                Documentation
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @(User.Identity.Name ?? "Account")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-page="/Account/Manage">My account</a></li>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Owner"))
                                    {
                                        <li><a class="dropdown-item" asp-page="/Admin/Dashboard">Admin</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-page="/Account/Logout">
                                            <button type="submit" class="dropdown-item">Sign out</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a asp-page="/Account/Login" class="nav-link">Sign in</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>

        <div class="search-bar">
            <div class="container">
                <form action="@Url.Page("/Index")" method="get">
                    <div class="input-group">
                        <input type="text"
                               name="q"
                               value="@ViewData["SearchQuery"]"
                               class="form-control"
                               autocomplete="off"
                               placeholder="Search packages..." />
                        <button type="submit" class="btn btn-search" title="Search for packages">
                            <span class="ms-Icon ms-Icon--Search" aria-hidden="true"></span>
                        </button>
                    </div>
                    @await RenderSectionAsync("SearchForm", required: false)
                </form>
            </div>
        </div>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container text-center py-3">
            <small>Version: @Version.Version</small>
        </div>
        @Html.AddReleaseInformationAsComment()
    </footer>

    <script src="~/_content/BaGetter.Web/lib/alpinejs/dist/alpine.js"></script>
    <script src="~/_content/BaGetter.Web/lib/bootstrap/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/_content/BaGetter.Web/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
