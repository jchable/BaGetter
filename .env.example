# Copy this file to .env and fill in your values before running docker compose.
# Never commit .env to version control.

# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-password

# BaGetter application
BAGETTER_API_KEY=change-me-random-64-char-string
BAGETTER_USER=admin
BAGETTER_PASSWORD=change-me-strong-password
